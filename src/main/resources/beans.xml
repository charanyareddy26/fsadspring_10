<beans xmlns="http://www.springframework.org/schema/beans"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
 xsi:schemaLocation=" http://www.springframework.org/schema/beans 
 http://www.springframework.org/schema/beans/spring-beans.xsd">
 
<!--  Dependency  -->
<bean id="faculty" class="model.Faculty">
<property name="fid" value="101"/>
<property name="fname" value="XXXXXX"/>
</bean>

<!--  Dependent  -->
<bean id="course" class="model.Course">
<constructor-arg name="coursecode" value=" 26CS001"/>
<constructor-arg name="coursename" value="  Full Stack Application Development"/>
<constructor-arg name="faculty" ref="faculty"/>
</bean>
</beans>